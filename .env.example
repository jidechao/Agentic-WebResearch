# 复制本文件为 .env 并填入真实密钥（.env 不入库；本文件仅作模板）。
# 密钥缺失会在启动时直接报错（fail-fast）。详见 README「配置」一节。

# DeepSeek API Key —— 申请：https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# 博查（Bocha）搜索 API Key —— 申请：https://open.bochaai.com/
BOCHA_API_KEY=

# DeepSeek 模型 id（可选，默认 deepseek-v4-flash；可换成你账号可用的型号，如 deepseek-chat）
DEEPSEEK_MODEL=deepseek-v4-flash
